# Copy this file to .env and edit the values before starting Devfleet.

# Local service passwords. Change these on any shared or public server.
NATS_TOKEN=change-me
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# Optional: set this to use an external MySQL/TiDB database instead of the
# bundled MySQL service from deploy/compose.local.yaml.
# DATABASE_DSN=user:password@tcp(host:3306)/devfleet?parseTime=true

# Optional bearer token for the MCP endpoint. Set this for public servers.
DEVFLEET_MCP_AUTH_TOKEN=change-me-mcp-token

# Runner provider keys. Configure at least one provider your OpenCode setup can use.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
SYNTHETIC_API_KEY=
OPENCODE_API_KEY=

# Optional GitHub token for agents that need to clone private repos or create PRs.
GITHUB_TOKEN=

# Optional persistent memory provider.
MEM9_API_KEY=
MEM9_API_URL=https://api.mem9.ai
MEM9_DEBUG=false
